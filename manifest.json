{
  "manifest_version": 3,
  "name": "Recipe Card",
  "version": "1.0.0",
  "description": "Turn any recipe page into a clean, minimal recipe card you can copy or save as an image.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Make a recipe card"
  },
  "permissions": ["activeTab", "scripting"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
